function selectAvailStatus(status, resetDate = true) {
  selectedAvailStatus = status;
  ['available','unavailable'].forEach(s => {
    const btn = document.getElementById('avail-btn-' + s);
    if (btn) btn.className = 'avail-big-btn' + (s === status ? ' sel-' + s : '');
  });
  const dateRow = document.getElementById('avail-date-row');
  if (status === 'date') {
    dateRow.classList.add('show');
    document.getElementById('avail-btn-unavailable').className = 'avail-big-btn';
    document.getElementById('avail-btn-available').className = 'avail-big-btn sel-date';
