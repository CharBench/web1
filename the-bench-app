        { id: 'The_Bench_Project_Code', label: 'The Bench Project Code', type: 'text', req: true, ph: 'e.g. B26-004' },
        { id: 'Client',          label: 'Client',                   type: 'text',     req: true,  ph: 'Client organisation name' },
      ]},
      { title: 'Project Details', fields: [
        { id: 'Client_Contact_Details', label: 'Client Contact Details', type: 'textarea', req: false, ph: 'Name, Email, Phone' },
        { id: 'Project_Dates',   label: 'Project Dates',            type: 'text',     req: true,  ph: 'Month Year – Month Year  (e.g. Jan 2024 – Mar 2025)' },
        { id: 'Value_of_Engagement', label: 'Value of Engagement', type: 'text',     req: false, ph: 'e.g. $50,000' },
        { id: 'Bench_Warmers_Involved', label: 'Bench Warmers Involved', type: 'textarea', req: false, ph: 'List names of team members who worked on this project.' },
        { id: 'Scope_of_Work',   label: 'Scope of Work',            type: 'textarea', req: true,  ph: 'Describe the scope of work delivered.' },
      ]},
      { title: 'Highlight Content', fields: [
        { id: 'Our_Involvement', label: 'Our Involvement',          type: 'textarea', req: true,  ph: "Briefly describe our role in the project. Highlight how the client benefitted from our engagement with them, particularly citing any financial or quality improvements attributed to our work.", tall: true },
        { id: 'Client_Testimonial', label: 'Client Testimonial',   type: 'textarea', req: false, ph: 'Paste a testimonial received from the client.', tall: true },
