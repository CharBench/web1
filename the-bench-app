// ── PROJECT CODE GENERATOR ────────────────────────────────────────────────────
function generateProjectCode() {
  const year = new Date().getFullYear().toString().slice(-2);
  const count = LISTS['project-register'].items.length + 1;
  return 'B' + year + '-' + String(count).padStart(3, '0');
}

