// ── AUTO-ADD RSVP TO EMAIL LIST ───────────────────────────────────────────────
function syncRSVPToEmailList(entry) {
  const emailList = LISTS['email-list'];
  const existing = emailList.items.find(x => x.Email && x.Email.toLowerCase() === (entry.email || '').toLowerCase());
  if (existing) {
    // Update RSVP status on existing contact
    existing.RSVP = entry.Attending === 'Yes' ? 'Yes' : 'No';
    showToast('RSVP updated in Email List', 'success');
  } else {
    // Add new contact
    emailList.items.unshift({
      _id: Date.now() + 1,
      Name: entry.Name || '',
      Email: entry.email || '',
      Company: '',
      RSVP: entry.Attending === 'Yes' ? 'Yes' : 'No',
      Date_Added: new Date().toLocaleDateString('en-AU')
    });
    showToast('Added to Bench Chambers Email List', 'success');
  }
  saveLists();
  updateListCounts();
}

