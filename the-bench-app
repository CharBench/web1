}

function exportCSV() {
  const f = FORMS[activeFormId];
  if (!f.responses.length) { showToast('No responses to export.'); return; }
  const keys = Object.keys(f.responses[0]).filter(k => !k.startsWith('_'));
  const csv = [['Submitted', 'Status', ...keys].join(','),
    ...f.responses.map(r => [r._submitted, r._status, ...keys.map(k => '"' + (r[k] || '').replace(/"/g, '""') + '"')].join(','))
  ].join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv,' + encodeURIComponent(csv);
  a.download = f.slug + '-responses.csv';
  a.click();
