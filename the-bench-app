const ADMIN_EMAILS = [
  'aidan@thebench.au',
  'anthony@thebench.au',
  'charlie.simpson@thebench.au'
];

const ADMIN_ONLY_VIEWS = ['lists','sharepoint'];

// MSAL configuration
const msalConfig = {
  auth: {
    clientId: '82b9a5bb-64ae-42e5-9776-13dd728844d8',
    authority: 'https://login.microsoftonline.com/ba4d31a9-4750-43e1-8a95-7ded08d4dd45',
    redirectUri: window.location.origin + window.location.pathname,
  },
  cache: { cacheLocation: 'sessionStorage', storeAuthStateInCookie: false }
};

let msalInstance = null;
let currentUser = null;
let currentRole = 'benchwarmer';
try {
  msalInstance = new msal.PublicClientApplication(msalConfig);
} catch(e) {
  console.error('MSAL failed to initialise:', e);
}

async function initAuth() {
  try {
    // Handle redirect response (called after Microsoft redirects back)
    const response = await msalInstance.handleRedirectPromise();
    if (response) {
      handleAuthResponse(response);
      return;
    }
    // Check for existing session
    const accounts = msalInstance.getAllAccounts();
    if (accounts.length > 0) {
      currentUser = accounts[0];
      onSignedIn();
    }
    // else: login screen stays visible
  } catch (e) {
    console.error('Auth init error:', e);
  }
}

function handleAuthResponse(response) {
  if (response && response.account) {
    currentUser = response.account;
    onSignedIn();
  }
}

function onSignedIn() {
  const email = (currentUser.username || '').toLowerCase();
  currentRole = ADMIN_EMAILS.includes(email) ? 'admin' : 'benchwarmer';

  // Hide login screen, show app
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('user-bar').style.display = 'flex';

  // User bar
  const name = currentUser.name || email;
  document.getElementById('user-name').textContent = name;
  const initials = name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('user-initials').textContent = initials;
  const badge = document.getElementById('user-role-badge');
  badge.textContent = currentRole === 'admin' ? 'Admin' : 'Bench Warmer';
  badge.className = 'user-bar-role ' + (currentRole === 'admin' ? 'admin' : 'benchwarmer');

  applyRole();
}

async function signIn() {
  document.getElementById('login-loading').style.display = 'block';
  document.getElementById('login-error').style.display = 'none';
  try {
    await msalInstance.loginRedirect({
      scopes: ['User.Read', 'Sites.ReadWrite.All', 'Mail.Send']
    });
  } catch (e) {
    document.getElementById('login-loading').style.display = 'none';
    document.getElementById('login-error').style.display = 'block';
    console.error('Sign-in error:', e);
  }
}

function signOut() {
  msalInstance.logoutRedirect({ account: currentUser });
}

function applyRole() {
  const isAdmin = currentRole === 'admin';

  // Nav visibility
  document.getElementById('nav-lists').style.display      = isAdmin ? '' : 'none';
  document.getElementById('nav-sharepoint').style.display = isAdmin ? '' : 'none';

  // Role toggle pill (still visible for admins to verify role)
  const pill = document.getElementById('role-pill');
  if (pill) {
    pill.textContent = isAdmin ? 'Admin' : 'Bench Warmer';
    pill.className = 'role-pill ' + (isAdmin ? 'admin' : 'benchwarm');
  }

  // Redirect away from admin-only views if benchwarmer
  const activeView = document.querySelector('.view.active');
  if (!isAdmin && activeView) {
    const vid = activeView.id.replace('view-', '');
    if (ADMIN_ONLY_VIEWS.includes(vid)) showView('dashboard');
  }

  // Dashboard cards
  const listsCard = document.querySelector('.module-card[onclick*=\'lists\']');
  const spCard    = document.querySelector('.module-card[onclick*=\'sharepoint\']');
  if (listsCard) listsCard.style.display = isAdmin ? '' : 'none';
  if (spCard)    spCard.style.display    = isAdmin ? '' : 'none';
}

function toggleRole() {
  // Keep dev toggle for admin users only (hidden in production)
  if (currentRole !== 'admin') return;
  const pill = document.getElementById('role-pill');
  const previewingAs = pill && pill.dataset.preview === 'benchwarmer' ? 'admin' : 'benchwarmer';
  if (pill) pill.dataset.preview = previewingAs;

  const isAdmin = previewingAs === 'admin';
  document.getElementById('nav-lists').style.display      = isAdmin ? '' : 'none';
  document.getElementById('nav-sharepoint').style.display = isAdmin ? '' : 'none';
  if (pill) {
    pill.textContent = isAdmin ? 'Admin (you)' : 'Bench Warmer preview';
    pill.className = 'role-pill ' + (isAdmin ? 'admin' : 'benchwarm');
  }
  const listsCard = document.querySelector('.module-card[onclick*=\'lists\']');
  const spCard    = document.querySelector('.module-card[onclick*=\'sharepoint\']');
  if (listsCard) listsCard.style.display = isAdmin ? '' : 'none';
  if (spCard)    spCard.style.display    = isAdmin ? '' : 'none';
  if (!isAdmin) {
    const activeView = document.querySelector('.view.active');
    if (activeView) {
      const vid = activeView.id.replace('view-', '');
      if (ADMIN_ONLY_VIEWS.includes(vid)) showView('dashboard');
    }
  }
  showToast('Previewing as ' + (isAdmin ? 'Admin' : 'Bench Warmer'));
}
