// ── LIST RENDERER ─────────────────────────────────────────────────────────────
function renderList() {
  const list = LISTS[activeListId];
  const s = (document.getElementById('list-search').value || '').toLowerCase();
  const rows = list.items.filter(r => !s || JSON.stringify(r).toLowerCase().includes(s));
  const wrap = document.getElementById('list-table-wrap');

  if (!rows.length) {
    wrap.innerHTML = `<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg><p>No items yet${s ? ' matching your search' : ''}.</p></div>`;
    return;
  }

  const visibleCols = list.cols.slice(0, 6); // show first 6 cols in table, rest in edit modal

  let h = `<table class="ie-table"><thead><tr>`;
  visibleCols.forEach(c => h += `<th style="min-width:${c.width}">${c.label}</th>`);
  h += `<th></th></tr></thead><tbody>`;

  rows.forEach(r => {
    const isEditing = editingItemId === r._id;
    h += `<tr class="${isEditing ? 'editing' : ''}">`;
    visibleCols.forEach(c => {
      const val = r[c.id] || '';
      if (isEditing && !c.readonly) {
        if (c.type === 'select') {
          h += `<td><select class="ie-cell-select" id="ie-${c.id}">${c.opts.map(o => `<option value="${o}"${val===o?' selected':''}>${o}</option>`).join('')}</select></td>`;
        } else {
          h += `<td><input class="ie-cell-input" type="${c.type}" id="ie-${c.id}" value="${val}" /></td>`;
        }
      } else {
        h += `<td>${renderCellValue(c, val)}</td>`;
      }
    });
    if (isEditing) {
      h += `<td><div class="ie-row-actions">
        <button class="btn btn-primary btn-sm" onclick="saveItemEdit(${r._id})">Save</button>
        <button class="btn btn-secondary btn-sm" onclick="cancelEdit()">Cancel</button>
        <button class="btn btn-sm" style="color:#dc2626;background:#fee2e2;border:none;" onclick="deleteItem(${r._id})">Delete</button>
      </div></td>`;
    } else {
      h += `<td><div class="ie-row-actions">
        <button class="link-btn" onclick="startEdit(${r._id})">Edit <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 2l2 2-6 6H2V8z"/></svg></button>
        <button class="link-btn" onclick="openItemDetail(${r._id})" style="margin-left:6px;">View <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5 2 10 6 5 10"/></svg></button>
      </div></td>`;
    }
    h += `</tr>`;
  });

  h += `</tbody></table>`;
  wrap.innerHTML = h;
}

function renderCellValue(col, val) {
  if (!val) return `<span style="color:var(--text-muted)">—</span>`;
  if (col.id === 'Project_Code') return `<span class="proj-code">${val}</span>`;
  if (col.id === 'Status') {
    const map = {'Pending Approval':'pending','Active':'active','Completed':'completed','Cancelled':'cancelled'};
    return `<span class="pill pill-${map[val]||'pending'}">${val}</span>`;
  }
  if (col.id === 'RSVP') return `<span class="pill pill-${val.toLowerCase()==='yes'?'yes':'no'}">${val}</span>`;
  return `<span class="ie-cell-view">${val}</span>`;
}

