// ── CV PROCESSOR ──────────────────────────────────────────────────────────────
let cvFile = null;
let cvFileData = null;
const CV_HISTORY_KEY = 'thebench_cv_history';
let cvHistory = [];

function loadCVHistory() {
  try {
    const raw = localStorage.getItem(CV_HISTORY_KEY);
    if (raw) cvHistory = JSON.parse(raw);
    renderCVHistory();
  } catch(e) {}
}

function saveCVHistory() {
  try { localStorage.setItem(CV_HISTORY_KEY, JSON.stringify(cvHistory.slice(0, 20))); } catch(e) {}
}

function renderCVHistory() {
  const el = document.getElementById('cv-history');
  if (!cvHistory.length) {
    el.innerHTML = '<div style="text-align:center;padding:1.5rem;color:var(--text-muted);font-size:13px;">No profiles generated yet.</div>';
    return;
  }
  el.innerHTML = cvHistory.map((h, i) => `
    <div class="cv-history-item">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" style="width:16px;height:16px;color:var(--green-dark);flex-shrink:0;"><rect x="3" y="2" width="10" height="12" rx="1.5"/><line x1="5" y1="5" x2="11" y2="5"/><line x1="5" y1="7" x2="11" y2="7"/><line x1="5" y1="9" x2="8" y2="9"/></svg>
      <div class="cv-history-name">${h.name}</div>
      <div class="cv-history-date">${h.date}</div>
      <button class="link-btn" onclick="loadHistoryItem(${i})">View <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><polyline points="5 2 10 6 5 10"/></svg></button>
    </div>`).join('');
  const countEl = document.getElementById('dash-cv-count');
  if (countEl) countEl.textContent = cvHistory.length + ' profile' + (cvHistory.length !== 1 ? 's' : '') + ' generated';
}

function loadHistoryItem(i) {
  const h = cvHistory[i];
  if (!h) return;
  renderProfileOutput(h.html, h.name);
}

function cvFileSelected(input) {
  if (!input.files[0]) return;
  cvFile = input.files[0];
  document.getElementById('cv-file-name').textContent = cvFile.name;
  document.getElementById('cv-file-size').textContent = (cvFile.size / 1024).toFixed(1) + ' KB';
  document.getElementById('cv-file-info').style.display = 'flex';
  document.getElementById('cv-generate-btn').disabled = false;
  readFileAsBase64(cvFile);
}

function readFileAsBase64(file) {
  const reader = new FileReader();
  reader.onload = e => { cvFileData = e.target.result.split(',')[1]; };
  reader.readAsDataURL(file);
}

function clearCV() {
  cvFile = null;
  cvFileData = null;
  document.getElementById('cv-file-input').value = '';
  document.getElementById('cv-file-info').style.display = 'none';
  document.getElementById('cv-generate-btn').disabled = true;
}

function cvDragOver(e) { e.preventDefault(); document.getElementById('cv-drop-zone').classList.add('dragover'); }
function cvDragLeave(e) { document.getElementById('cv-drop-zone').classList.remove('dragover'); }
function cvDrop(e) {
  e.preventDefault();
  document.getElementById('cv-drop-zone').classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (file && (file.type === 'application/pdf' || file.name.endsWith('.docx'))) {
    const dt = new DataTransfer();
    dt.items.add(file);
    document.getElementById('cv-file-input').files = dt.files;
    cvFileSelected(document.getElementById('cv-file-input'));
  }
}

async function generateProfile() {
  if (!cvFile || !cvFileData) return;

  // Show processing state
  document.getElementById('cv-output-body').innerHTML = `
    <div class="cv-processing">
      <div class="cv-processing-spinner"></div>
      <p>Reading CV and generating Bench Player Profile…</p>
      <p style="margin-top:6px;font-size:11.5px;color:var(--text-muted);">This usually takes 15–30 seconds.</p>
    </div>`;
  document.getElementById('cv-output-actions').style.display = 'none';
  document.getElementById('cv-generate-btn').disabled = true;

  const mediaType = cvFile.type === 'application/pdf' ? 'application/pdf' : 'application/vnd.openxmlformats-officedocument.wordprocessingml.document';

  const prompt = `You are processing a CV to reformat it into The Bench's branded "Bench Player Profile" format.

CRITICAL RULES:
- Only use information explicitly stated in the CV. Do not invent, infer, or add anything not present.
- If a section has no data in the CV (e.g. no career highlights), omit that section entirely.
- Preserve the person's exact words where possible, especially in summaries and achievement descriptions.
- The "Expertise" section should only appear if the CV contains clear skill/expertise areas.
- The "Career Highlights" section should only appear if the CV contains notable achievements per role.
- The "Qualifications" section should only appear if the CV lists qualifications/education.
- The "Affiliations & Other" section should only appear if the CV lists affiliations, memberships, or other items.

OUTPUT: Respond with a valid JSON object only. No markdown, no explanation, just JSON.

{
  "name": "Full name",
  "role": "Current role/title at The Bench or most recent role",
  "email": "email if present, else null",
  "location": "location if present, else null",
  "summary": "Professional summary paragraph",
  "expertise": [
    { "header": "Category name", "points": ["point 1", "point 2", "point 3"] }
  ],
  "experience": [
    { "org": "Organisation", "role": "Role title", "dates": "Date range" }
  ],
  "highlights": [
    { "org": "Organisation", "role": "Role title", "achievement": "Achievement description" }
  ],
  "qualifications": ["Qualification 1", "Qualification 2"],
  "affiliations": ["Affiliation 1", "Affiliation 2"]
}

If expertise/highlights/qualifications/affiliations are not present in the CV, return them as empty arrays [].`;

  try {
    const response = await fetch('/api/anthropic', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 2000,
        messages: [{
          role: 'user',
          content: [
            { type: 'document', source: { type: 'base64', media_type: mediaType, data: cvFileData } },
            { type: 'text', text: prompt }
          ]
        }]
      })
    });

    const data = await response.json();
    const text = data.content?.find(b => b.type === 'text')?.text || '';
    const clean = text.replace(/```json|```/g, '').trim();
    const profile = JSON.parse(clean);
    const html = buildProfileHTML(profile);
    const name = profile.name || cvFile.name.replace(/\.[^.]+$/, '');

    // Save to history
    cvHistory.unshift({ name, date: new Date().toLocaleDateString('en-AU'), html });
    saveCVHistory();
    renderCVHistory();

    renderProfileOutput(html, name);
    showToast('Profile generated!', 'success');

  } catch(err) {
    document.getElementById('cv-output-body').innerHTML = `
      <div style="padding:1.5rem;text-align:center;color:#dc2626;">
        <p style="font-weight:700;">Something went wrong</p>
        <p style="font-size:12.5px;margin-top:6px;color:var(--text-muted);">${err.message}</p>
      </div>`;
    showToast('Generation failed — check console for details.');
  }
  document.getElementById('cv-generate-btn').disabled = false;
}

function buildProfileHTML(p) {
  let html = `<div class="bpp" id="bpp-printable">`;

  // Header
  html += `<div class="bpp-header">
    <div class="bpp-title"><span>Bench Player</span> Profile</div>
    <div class="bpp-name">${p.name || ''}</div>
    <div class="bpp-role">${p.role || ''}</div>
    <div class="bpp-contact">`;
  if (p.email) html += `<span><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="4" width="12" height="9" rx="1.5"/><polyline points="2 6 8 10 14 6"/></svg> ${p.email}</span>`;
  if (p.location) html += `<span><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="8" cy="7" r="3"/><path d="M8 2C5.24 2 3 4.24 3 7c0 3.5 5 9 5 9s5-5.5 5-9c0-2.76-2.24-5-5-5z"/></svg> ${p.location}</span>`;
  html += `</div>`;
  if (p.summary) html += `<div class="bpp-summary">${p.summary}</div>`;
  html += `</div>`;

  // Expertise
  if (p.expertise && p.expertise.length) {
    html += `<div class="bpp-section-title">Expertise</div>`;
    html += `<div class="bpp-expertise-grid">`;
    html += `<div style="display:contents;">`;
    p.expertise.forEach(col => {
      html += `<div class="bpp-expertise-col-header">${col.header}</div>`;
    });
    html += `</div>`;
    const maxRows = Math.max(...p.expertise.map(c => c.points.length));
    for (let i = 0; i < maxRows; i++) {
      html += `<div style="display:contents;" class="bpp-expertise-row">`;
      p.expertise.forEach(col => {
        html += `<div class="bpp-expertise-cell">${col.points[i] || ''}</div>`;
      });
      html += `</div>`;
    }
    html += `</div>`;
  }

  // Experience
  if (p.experience && p.experience.length) {
    html += `<div class="bpp-section-title">Experience</div>`;
    html += `<table class="bpp-exp-table">`;
    p.experience.forEach(e => {
      html += `<tr><td class="bpp-exp-org">${e.org}</td><td class="bpp-exp-role">${e.role}</td><td class="bpp-exp-dates">${e.dates}</td></tr>`;
    });
    html += `</table>`;
  }

  // Career Highlights
  if (p.highlights && p.highlights.length) {
    html += `<div class="bpp-section-title">Career Highlights</div>`;
    html += `<table class="bpp-highlights-table"><thead><tr><th class="bpp-hl-role">Role</th><th>Achievements</th></tr></thead><tbody>`;
    p.highlights.forEach(h => {
      html += `<tr><td class="bpp-hl-role"><strong>${h.org}</strong><br/><span style="font-weight:400;color:var(--text-muted);font-size:11.5px;">${h.role}</span></td><td>${h.achievement}</td></tr>`;
    });
    html += `</tbody></table>`;
  }

  // Qualifications + Affiliations
  const hasQual = p.qualifications && p.qualifications.length;
  const hasAffil = p.affiliations && p.affiliations.length;
  if (hasQual || hasAffil) {
    html += `<div class="bpp-two-col">`;
    if (hasQual) {
      html += `<div><div class="bpp-section-title">Qualifications</div><ul class="bpp-list">`;
      p.qualifications.forEach(q => html += `<li>${q}</li>`);
      html += `</ul></div>`;
    }
    if (hasAffil) {
      html += `<div><div class="bpp-section-title">Affiliations & Other</div><ul class="bpp-list">`;
      p.affiliations.forEach(a => html += `<li>${a}</li>`);
      html += `</ul></div>`;
    }
    html += `</div>`;
  }

  html += `<div class="bpp-footer">All Bench Player referrals are subject to The Bench (Aus)'s Standard Terms &amp; Conditions unless otherwise agreed in writing.<br/>© The Bench (Aus), ${new Date().getFullYear()}</div>`;
  html += `</div>`;
  return html;
}

function renderProfileOutput(html, name) {
  document.getElementById('cv-output-body').innerHTML = html;
  const actions = document.getElementById('cv-output-actions');
  actions.style.display = 'flex';
}

function printProfile() {
  const content = document.getElementById('bpp-printable');
  if (!content) return;
  const w = window.open('', '_blank');
  w.document.write(`<!DOCTYPE html><html><head><title>Bench Player Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Aptos:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
      body{font-family:'Aptos','Calibri Light',Calibri,sans-serif;font-size:13px;color:#333;padding:2rem;max-width:800px;margin:0 auto;}
      ${document.querySelector('style').innerHTML}
    </style></head><body>${content.outerHTML}</body></html>`);
  w.document.close();
  w.focus();
  setTimeout(() => w.print(), 500);
}

