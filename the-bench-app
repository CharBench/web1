<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>The Bench — Operations Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Aptos:wght@300;400;700;900&display=swap" rel="stylesheet">
<style>
  :root{--green:#73bf43;--green-dark:#5a9e32;--green-light:#e9f5df;--green-xlight:#f4faf0;--grey:#58585a;--grey-light:#e8e8e8;--grey-xlight:#f5f5f5;--white:#ffffff;--text:#2d2d2e;--text-muted:#6b6b6d;--border:#d8d8d8;--radius:10px;--radius-sm:6px;}
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Aptos','Calibri Light',Calibri,sans-serif;background:var(--grey-xlight);color:var(--text);min-height:100vh;font-size:14px;line-height:1.5;}
  /* NAV */
  nav{background:var(--white);border-bottom:2px solid var(--green);padding:0 2rem;display:flex;align-items:center;height:60px;gap:2rem;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.06);}
  .nav-logo{display:flex;align-items:center;gap:10px;font-weight:700;font-size:18px;color:var(--grey);cursor:pointer;}
  .nav-logo-mark{width:32px;height:32px;background:var(--green);border-radius:8px;display:flex;align-items:center;justify-content:center;color:white;font-weight:900;font-size:16px;}
  .nav-links{display:flex;gap:.25rem;flex:1;}
  .nav-link{padding:.4rem .85rem;border-radius:var(--radius-sm);font-size:13.5px;font-weight:400;color:var(--text-muted);cursor:pointer;border:none;background:none;transition:all .15s;display:flex;align-items:center;gap:6px;font-family:inherit;}
  .nav-link:hover{background:var(--green-xlight);color:var(--green-dark);}
  .nav-link.active{background:var(--green-light);color:var(--green-dark);font-weight:700;}
  .nav-link svg{width:16px;height:16px;flex-shrink:0;}
  .nav-avatar{width:30px;height:30px;background:var(--green);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:12px;}
  /* LAYOUT */
  main{max-width:1200px;margin:0 auto;padding:2rem 1.5rem;}
  .view{display:none;}.view.active{display:block;}
  /* DASHBOARD */
  .db-header{margin-bottom:2rem;}.db-header h1{font-size:26px;font-weight:700;margin-bottom:4px;}.db-header p{color:var(--text-muted);}
  .module-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:1.5rem;margin-bottom:2.5rem;}
  .module-card{background:var(--white);border-radius:var(--radius);border:1.5px solid var(--border);padding:1.5rem;cursor:pointer;transition:all .18s;position:relative;overflow:hidden;}
  .module-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--green);transform:scaleX(0);transform-origin:left;transition:transform .2s;}
  .module-card:hover{border-color:var(--green);box-shadow:0 4px 20px rgba(0,0,0,.12);transform:translateY(-2px);}
  .module-card:hover::before{transform:scaleX(1);}
  .module-icon{width:48px;height:48px;background:var(--green-light);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1rem;color:var(--green-dark);}
  .module-icon svg{width:24px;height:24px;}
  .module-card h2{font-size:17px;font-weight:700;margin-bottom:6px;}
  .module-card p{font-size:13px;color:var(--text-muted);line-height:1.5;margin-bottom:1.25rem;}
  .module-meta{display:flex;gap:.75rem;flex-wrap:wrap;}
  .module-cta{display:inline-flex;align-items:center;gap:6px;margin-top:.75rem;font-size:13px;font-weight:700;color:var(--green-dark);}
  /* BADGES */
  .badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:700;}
  .badge-green{background:var(--green-light);color:var(--green-dark);}
  .badge-grey{background:var(--grey-light);color:var(--grey);}
  /* BUTTONS */
  .btn{display:inline-flex;align-items:center;gap:6px;padding:.5rem 1.1rem;border-radius:var(--radius-sm);font-size:13.5px;font-weight:700;cursor:pointer;transition:all .15s;border:none;font-family:inherit;}
  .btn svg{width:15px;height:15px;}
  .btn-primary{background:var(--green);color:white;}.btn-primary:hover{background:var(--green-dark);}
  .btn-secondary{background:var(--white);color:var(--text);border:1.5px solid var(--border);}.btn-secondary:hover{border-color:var(--green);color:var(--green-dark);}
  .btn-ghost{background:none;color:var(--text-muted);border:none;}.btn-ghost:hover{color:var(--green-dark);}
  .btn-sm{padding:.3rem .75rem;font-size:12.5px;}
  .link-btn{background:none;border:none;color:var(--green-dark);font-size:12px;font-family:inherit;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:4px;padding:0;text-decoration:none;}
  .link-btn:hover{text-decoration:underline;}.link-btn svg{width:12px;height:12px;}
  /* SECTION HEADER */
  .section-header{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;}
  .section-header h1{font-size:22px;font-weight:700;flex:1;}
  /* PANEL */
  .panel-layout{display:grid;grid-template-columns:260px 1fr;gap:1.5rem;align-items:start;}
  .sidebar-panel{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
  .spanel-header{padding:.85rem 1rem;border-bottom:1px solid var(--border);font-weight:700;font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;display:flex;justify-content:space-between;align-items:center;}
  /* FORM LIST */
  .fli{padding:.85rem 1rem;border-bottom:1px solid var(--grey-xlight);cursor:pointer;transition:background .12s;display:flex;align-items:flex-start;gap:8px;}
  .fli:hover{background:var(--green-xlight);}.fli.active{background:var(--green-light);}
  .fli-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
  .fli-icon svg{width:14px;height:14px;}
  .fli-info{flex:1;min-width:0;}
  .fli-name{font-size:13px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .fli.active .fli-name{color:var(--green-dark);}
  .fli-desc{font-size:11.5px;color:var(--text-muted);margin-top:2px;}
  /* CONTENT PANEL */
  .content-panel{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
  .cp-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;}
  .cp-header h2{font-size:16px;font-weight:700;flex:1;min-width:160px;}
  /* TABS */
  .tabs{display:flex;gap:2px;background:var(--grey-xlight);border-radius:var(--radius-sm);padding:3px;}
  .tab-btn{padding:.3rem .85rem;border-radius:5px;font-size:12.5px;font-weight:400;cursor:pointer;border:none;background:none;color:var(--text-muted);font-family:inherit;transition:all .12s;}
  .tab-btn.active{background:var(--white);color:var(--text);font-weight:700;box-shadow:0 1px 3px rgba(0,0,0,.1);}
  .resp-count{background:var(--green-light);color:var(--green-dark);border-radius:10px;padding:1px 7px;font-size:11px;font-weight:700;}
  /* FORM RENDERER */
  .fv-wrap{padding:1.5rem;max-width:660px;}
  .fv-title{font-size:19px;font-weight:700;margin-bottom:4px;}
  .fv-desc{font-size:13px;color:var(--text-muted);margin-bottom:1.5rem;line-height:1.5;}
  .fv-section{font-size:11px;font-weight:700;color:var(--green-dark);text-transform:uppercase;letter-spacing:.07em;margin:1.5rem 0 .75rem;padding-bottom:6px;border-bottom:1.5px solid var(--green-light);}
  .fv-group{margin-bottom:1.1rem;}
  .fv-label{display:block;font-size:13px;font-weight:700;color:var(--text);margin-bottom:4px;}
  .fv-label .req{color:#c0392b;margin-left:3px;}
  .fv-hint{font-size:11.5px;color:var(--text-muted);margin-bottom:6px;font-style:italic;}
  .fv-input,.fv-select{width:100%;padding:.55rem .8rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13.5px;font-family:inherit;color:var(--text);background:var(--white);outline:none;transition:border-color .12s;}
  .fv-input:focus,.fv-select:focus{border-color:var(--green);}
  .fv-select{cursor:pointer;}
  .fv-textarea{width:100%;padding:.55rem .8rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13.5px;font-family:inherit;color:var(--text);background:var(--white);outline:none;transition:border-color .12s;resize:vertical;min-height:88px;}
  .fv-textarea:focus{border-color:var(--green);}
  .fv-textarea.tall{min-height:120px;}
  .fv-radio-group{display:flex;gap:8px;flex-wrap:wrap;}
  .fv-option-label{display:flex;align-items:center;gap:7px;font-size:13.5px;cursor:pointer;padding:.45rem .85rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);transition:border-color .12s;}
  .fv-option-label:hover{border-color:var(--green);background:var(--green-xlight);}
  .fv-option-label input{accent-color:var(--green);width:15px;height:15px;flex-shrink:0;}
  .fv-inline{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
  .fv-upload-area{border:1.5px dashed var(--border);border-radius:var(--radius-sm);padding:1rem;text-align:center;cursor:pointer;transition:all .12s;background:var(--grey-xlight);}
  .fv-upload-area:hover{border-color:var(--green);background:var(--green-xlight);}
  .fv-upload-area input{display:none;}
  .fv-upload-area p{font-size:12.5px;color:var(--text-muted);margin-top:4px;}
  .fv-upload-name{font-size:12.5px;color:var(--green-dark);font-weight:700;margin-top:6px;}
  .fv-conditional{padding:1rem;background:var(--grey-xlight);border-radius:var(--radius-sm);border-left:3px solid var(--green);margin-top:6px;}
  .form-submit-row{margin-top:1.75rem;padding-top:1.25rem;border-top:1px solid var(--border);display:flex;align-items:center;gap:1rem;}
  /* RESPONSES */
  .responses-view{padding:1.25rem;}
  .filter-row{display:flex;gap:.75rem;margin-bottom:1rem;flex-wrap:wrap;}
  .search-input{flex:1;min-width:180px;padding:.45rem .8rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:inherit;color:var(--text);background:var(--white);outline:none;}
  .search-input:focus{border-color:var(--green);}
  .filter-select{padding:.45rem .75rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13px;font-family:inherit;color:var(--text-muted);background:var(--white);cursor:pointer;outline:none;}
  .data-table{width:100%;border-collapse:collapse;font-size:13px;}
  .data-table th{text-align:left;padding:.6rem .85rem;font-weight:700;font-size:11.5px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;border-bottom:1.5px solid var(--border);background:var(--grey-xlight);}
  .data-table td{padding:.7rem .85rem;border-bottom:1px solid var(--grey-xlight);color:var(--text);vertical-align:middle;}
  .data-table tr:hover td{background:var(--green-xlight);}
  .data-table tr:last-child td{border-bottom:none;}
  .sdot{display:inline-flex;align-items:center;gap:5px;font-size:12px;}
  .sdot::before{content:'';width:7px;height:7px;border-radius:50%;flex-shrink:0;}
  .sdot.new::before{background:var(--green);}
  .sdot.reviewed::before{background:#f59e0b;}
  .sdot.approved::before{background:#2563eb;}
  .sdot.declined::before{background:#dc2626;}
  .empty-state{text-align:center;padding:3rem 1.5rem;color:var(--text-muted);}
  .empty-state svg{width:40px;height:40px;margin-bottom:.75rem;opacity:.3;}
  /* SHARE */
  .share-view{padding:1.25rem;}
  .form-group{margin-bottom:1rem;}
  .form-label{display:block;font-size:12.5px;font-weight:700;color:var(--text-muted);margin-bottom:4px;text-transform:uppercase;letter-spacing:.05em;}
  .form-input{width:100%;padding:.55rem .8rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13.5px;font-family:inherit;color:var(--text);background:var(--white);outline:none;}
  .form-select-full{width:100%;padding:.55rem .8rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:13.5px;font-family:inherit;color:var(--text);background:var(--white);outline:none;cursor:pointer;}
  /* SP */
  .sp-layout{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
  .sp-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
  .sp-card-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;}
  .sp-card-header h2{font-size:15px;font-weight:700;flex:1;}
  .sp-card-body{padding:1.25rem;}
  .tpl-option{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:.85rem 1rem;margin-bottom:8px;cursor:pointer;transition:all .12s;display:flex;align-items:flex-start;gap:10px;}
  .tpl-option:hover{border-color:var(--green);background:var(--green-xlight);}
  .tpl-option.selected{border-color:var(--green);background:var(--green-light);}
  .tpl-radio{width:16px;height:16px;border:2px solid var(--border);border-radius:50%;flex-shrink:0;margin-top:1px;position:relative;transition:border-color .12s;}
  .tpl-option.selected .tpl-radio{border-color:var(--green);}
  .tpl-option.selected .tpl-radio::after{content:'';position:absolute;top:2px;left:2px;width:8px;height:8px;border-radius:50%;background:var(--green);}
  .tpl-info h3{font-size:13.5px;font-weight:700;color:var(--text);}
  .tpl-info p{font-size:12px;color:var(--text-muted);margin-top:2px;}
  .tpl-folders{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px;}
  .folder-chip{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;background:var(--grey-xlight);border-radius:4px;font-size:11px;color:var(--text-muted);}
  .folder-chip svg{width:11px;height:11px;}
  .folder-tree{font-size:12.5px;color:var(--text-muted);}
  .fti{display:flex;align-items:center;gap:5px;padding:3px 0;}
  .fti svg{width:13px;height:13px;flex-shrink:0;}
  .fti-child{padding-left:18px;}.fti-child .fti{color:var(--text);}
  .recent-item{display:flex;align-items:center;gap:10px;padding:.65rem 0;border-bottom:1px solid var(--grey-xlight);font-size:13px;}
  .recent-item:last-child{border-bottom:none;}
  .recent-item svg{width:16px;height:16px;color:var(--green-dark);flex-shrink:0;}
  .ri-name{flex:1;font-weight:700;}
  .ri-meta{font-size:11.5px;color:var(--text-muted);}
  /* ACTIVITY */
  .act-feed{padding:0 1.25rem 1.25rem;}
  .act-item{display:flex;gap:10px;padding:.7rem 0;border-bottom:1px solid var(--grey-xlight);font-size:13px;}
  .act-item:last-child{border-bottom:none;}
  .act-dot{width:8px;height:8px;border-radius:50%;background:var(--green);margin-top:4px;flex-shrink:0;}
  .act-dot.grey{background:var(--grey);}
  .act-text{flex:1;}.act-time{color:var(--text-muted);font-size:11.5px;}
  /* MODAL */
  .modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:200;display:flex;align-items:center;justify-content:center;padding:1rem;opacity:0;pointer-events:none;transition:opacity .2s;}
  .modal-backdrop.open{opacity:1;pointer-events:all;}
  .modal{background:var(--white);border-radius:var(--radius);width:100%;max-width:520px;box-shadow:0 12px 40px rgba(0,0,0,.18);transform:translateY(20px);transition:transform .2s;}
  .modal-backdrop.open .modal{transform:translateY(0);}
  .modal-header{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;}
  .modal-header h2{font-size:16px;font-weight:700;flex:1;}
  .modal-body{padding:1.25rem 1.5rem;max-height:60vh;overflow-y:auto;}
  .modal-footer{padding:1rem 1.5rem;border-top:1px solid var(--border);display:flex;gap:.75rem;justify-content:flex-end;align-items:center;}
  /* TOAST */
  .toast{position:fixed;bottom:1.5rem;right:1.5rem;background:var(--text);color:white;padding:.75rem 1.25rem;border-radius:var(--radius-sm);font-size:13.5px;display:flex;align-items:center;gap:8px;box-shadow:0 4px 16px rgba(0,0,0,.2);transform:translateY(80px);opacity:0;transition:all .25s;z-index:999;max-width:320px;}
  .toast.show{transform:translateY(0);opacity:1;}
  .toast.success{background:var(--green-dark);}
  .toast svg{width:16px;height:16px;flex-shrink:0;}



  /* LOGIN SCREEN */
  .login-screen{position:fixed;inset:0;background:var(--grey-xlight);display:flex;align-items:center;justify-content:center;z-index:500;flex-direction:column;gap:0;}
  .login-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:2.5rem 2.5rem 2rem;max-width:400px;width:100%;box-shadow:0 4px 24px rgba(0,0,0,.08);text-align:center;}
  .login-logo{width:52px;height:52px;background:var(--green);border-radius:14px;display:flex;align-items:center;justify-content:center;color:white;font-weight:900;font-size:24px;margin:0 auto 1.25rem;}
  .login-title{font-size:22px;font-weight:700;color:var(--text);margin-bottom:6px;}
  .login-subtitle{font-size:13.5px;color:var(--text-muted);margin-bottom:2rem;line-height:1.5;}
  .btn-microsoft{background:#2f2f2f;color:white;width:100%;justify-content:center;padding:.75rem 1.5rem;font-size:14px;border-radius:var(--radius-sm);gap:10px;}
  .btn-microsoft:hover{background:#1a1a1a;}
  .btn-microsoft svg{width:18px;height:18px;flex-shrink:0;}
  .login-error{color:#dc2626;font-size:12.5px;margin-top:1rem;display:none;}
  .login-loading{color:var(--text-muted);font-size:13px;margin-top:1rem;display:none;}
  .user-bar{background:var(--green-xlight);border-bottom:1px solid var(--green-light);padding:.5rem 2rem;display:flex;align-items:center;gap:.75rem;font-size:13px;}
  .user-bar-name{font-weight:700;color:var(--text);flex:1;}
  .user-bar-role{font-size:11.5px;font-weight:700;padding:2px 8px;border-radius:10px;}
  .user-bar-role.admin{background:var(--green-light);color:var(--green-dark);}
  .user-bar-role.benchwarmer{background:#e3f0ff;color:#1a5fbd;}
  /* ROLE TOGGLE */
  .role-toggle{position:fixed;bottom:1.5rem;left:1.5rem;background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:.6rem .85rem;display:flex;align-items:center;gap:.6rem;font-size:12.5px;box-shadow:0 2px 12px rgba(0,0,0,.1);z-index:90;cursor:pointer;transition:border-color .15s;}
  .role-toggle:hover{border-color:var(--green);}
  .role-toggle-label{font-weight:700;color:var(--text-muted);font-size:11px;text-transform:uppercase;letter-spacing:.05em;}
  .role-pill{padding:3px 10px;border-radius:20px;font-size:12px;font-weight:700;transition:all .15s;}
  .role-pill.admin{background:var(--green-light);color:var(--green-dark);}
  .role-pill.benchwarm{background:#e3f0ff;color:#1a5fbd;}
  .role-toggle-hint{font-size:10.5px;color:var(--text-muted);margin-top:1px;}
  /* MODULE VISIBILITY */
  .admin-only{transition:opacity .2s;}
  .benchwarm-only{transition:opacity .2s;}
  /* LISTS MODULE */
  .lists-layout{display:grid;grid-template-columns:220px 1fr;gap:1.5rem;align-items:start;}
  .list-sidebar{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
  .list-sidebar-header{padding:.85rem 1rem;border-bottom:1px solid var(--border);font-weight:700;font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;}
  .list-nav-item{padding:.85rem 1rem;border-bottom:1px solid var(--grey-xlight);cursor:pointer;transition:background .12s;display:flex;align-items:center;gap:10px;}
  .list-nav-item:hover{background:var(--green-xlight);}
  .list-nav-item.active{background:var(--green-light);}
  .list-nav-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .list-nav-icon svg{width:14px;height:14px;}
  .list-nav-name{font-size:13px;font-weight:700;color:var(--text);}
  .list-nav-item.active .list-nav-name{color:var(--green-dark);}
  .list-nav-count{font-size:11px;color:var(--text-muted);margin-top:1px;}
  .list-panel{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
  .list-panel-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;flex-wrap:wrap;}
  .list-panel-header h2{font-size:16px;font-weight:700;flex:1;}
  .list-panel-body{padding:1.25rem;}
  .list-toolbar{display:flex;gap:.75rem;margin-bottom:1rem;flex-wrap:wrap;align-items:center;}
  .list-toolbar-right{margin-left:auto;display:flex;gap:.75rem;}
  /* INLINE EDIT TABLE */
  .ie-table{width:100%;border-collapse:collapse;font-size:13px;}
  .ie-table th{text-align:left;padding:.6rem .85rem;font-weight:700;font-size:11.5px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.05em;border-bottom:1.5px solid var(--border);background:var(--grey-xlight);white-space:nowrap;}
  .ie-table td{padding:.65rem .85rem;border-bottom:1px solid var(--grey-xlight);vertical-align:middle;}
  .ie-table tr:hover td{background:var(--green-xlight);}
  .ie-table tr:last-child td{border-bottom:none;}
  .ie-table tr.editing td{background:#fffbf0;border-bottom:1px solid #f59e0b;}
  .ie-cell-view{font-size:13px;color:var(--text);cursor:pointer;}
  .ie-cell-view:hover{color:var(--green-dark);}
  .ie-cell-input{width:100%;padding:.3rem .5rem;border:1.5px solid var(--green);border-radius:4px;font-size:13px;font-family:inherit;background:var(--white);outline:none;}
  .ie-cell-select{width:100%;padding:.3rem .5rem;border:1.5px solid var(--green);border-radius:4px;font-size:13px;font-family:inherit;background:var(--white);outline:none;cursor:pointer;}
  .ie-row-actions{display:flex;gap:6px;white-space:nowrap;}
  /* PROJECT CODE BADGE */
  .proj-code{display:inline-block;background:var(--green-light);color:var(--green-dark);border-radius:4px;padding:2px 8px;font-size:12px;font-weight:700;font-family:monospace;}
  /* STATUS PILLS */
  .pill{display:inline-flex;align-items:center;padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:700;}
  .pill-pending{background:#fff3e0;color:#e65100;}
  .pill-active{background:var(--green-light);color:var(--green-dark);}
  .pill-completed{background:#e3f0ff;color:#1a5fbd;}
  .pill-cancelled{background:var(--grey-light);color:var(--grey);}
  .pill-yes{background:var(--green-light);color:var(--green-dark);}
  .pill-no{background:var(--grey-light);color:var(--grey);}


  /* AVAILABILITY MODULE */
  .avail-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem;margin-bottom:1.5rem;}
  .avail-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:1.25rem;transition:all .15s;position:relative;}
  .avail-card:hover{border-color:var(--green);box-shadow:0 2px 12px rgba(0,0,0,.08);}
  .avail-card-name{font-size:15px;font-weight:700;color:var(--text);margin-bottom:2px;}
  .avail-card-role{font-size:12px;color:var(--text-muted);margin-bottom:.85rem;}
  .avail-status-row{display:flex;align-items:center;gap:.5rem;margin-bottom:.75rem;flex-wrap:wrap;}
  .avail-btn{flex:1;min-width:0;padding:.4rem .5rem;border-radius:var(--radius-sm);font-size:12px;font-weight:700;cursor:pointer;border:1.5px solid var(--border);background:var(--white);font-family:inherit;transition:all .12s;text-align:center;}
  .avail-btn:hover{border-color:var(--green);}
  .avail-btn.selected-available{background:#dcfce7;border-color:#16a34a;color:#16a34a;}
  .avail-btn.selected-unavailable{background:#fee2e2;border-color:#dc2626;color:#dc2626;}
  .avail-btn.selected-date{background:#e3f0ff;border-color:#1a5fbd;color:#1a5fbd;}
  .avail-date-input{width:100%;padding:.4rem .65rem;border:1.5px solid var(--border);border-radius:var(--radius-sm);font-size:12.5px;font-family:inherit;color:var(--text);background:var(--white);outline:none;margin-top:.5rem;}
  .avail-date-input:focus{border-color:var(--green);}
  .avail-save-btn{width:100%;margin-top:.75rem;padding:.4rem;border-radius:var(--radius-sm);font-size:12.5px;font-weight:700;cursor:pointer;border:none;background:var(--green);color:white;font-family:inherit;transition:background .12s;}
  .avail-save-btn:hover{background:var(--green-dark);}
  .avail-last-updated{font-size:11px;color:var(--text-muted);margin-top:.5rem;text-align:right;}
  .avail-status-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11.5px;font-weight:700;}
  .avail-status-badge.available{background:#dcfce7;color:#16a34a;}
  .avail-status-badge.unavailable{background:#fee2e2;color:#dc2626;}
  .avail-status-badge.date{background:#e3f0ff;color:#1a5fbd;}
  .avail-status-badge::before{content:'';width:6px;height:6px;border-radius:50%;background:currentColor;}
  /* Quick update panel */
  .avail-quick-panel{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);padding:2rem;max-width:480px;margin:0 auto;}
  .avail-quick-name{font-size:22px;font-weight:700;margin-bottom:4px;}
  .avail-quick-sub{font-size:13px;color:var(--text-muted);margin-bottom:1.5rem;}
  .avail-big-btns{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1rem;}
  .avail-big-btn{padding:1.25rem 1rem;border-radius:var(--radius);font-size:14px;font-weight:700;cursor:pointer;border:2px solid var(--border);background:var(--white);font-family:inherit;transition:all .15s;text-align:center;display:flex;flex-direction:column;align-items:center;gap:.5rem;}
  .avail-big-btn svg{width:28px;height:28px;}
  .avail-big-btn:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(0,0,0,.1);}
  .avail-big-btn.sel-available{background:#dcfce7;border-color:#16a34a;color:#16a34a;}
  .avail-big-btn.sel-unavailable{background:#fee2e2;border-color:#dc2626;color:#dc2626;}
  .avail-big-btn.sel-date{background:#e3f0ff;border-color:#1a5fbd;color:#1a5fbd;}
  .avail-date-row{background:var(--grey-xlight);border-radius:var(--radius-sm);padding:1rem;margin-bottom:1rem;display:none;}
  .avail-date-row.show{display:block;}
  /* CV / PLAYER PROFILE MODULE */
  .cv-layout{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;align-items:start;}
  .cv-upload-panel,.cv-output-panel{background:var(--white);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;}
  .cv-panel-header{padding:1rem 1.25rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:.75rem;}
  .cv-panel-header h2{font-size:15px;font-weight:700;flex:1;}
  .cv-panel-body{padding:1.5rem;}
  .cv-drop-zone{border:2px dashed var(--border);border-radius:var(--radius);padding:2.5rem 1.5rem;text-align:center;cursor:pointer;transition:all .15s;background:var(--grey-xlight);}
  .cv-drop-zone:hover,.cv-drop-zone.dragover{border-color:var(--green);background:var(--green-xlight);}
  .cv-drop-zone svg{width:36px;height:36px;color:var(--text-muted);margin-bottom:.75rem;}
  .cv-drop-zone p{font-size:13px;color:var(--text-muted);margin-top:4px;}
  .cv-drop-zone strong{font-size:14px;color:var(--text);}
  .cv-file-selected{display:flex;align-items:center;gap:10px;padding:.85rem 1rem;background:var(--green-xlight);border:1.5px solid var(--green-light);border-radius:var(--radius-sm);margin-top:1rem;}
  .cv-file-selected svg{width:18px;height:18px;color:var(--green-dark);flex-shrink:0;}
  .cv-file-name{flex:1;font-size:13px;font-weight:700;color:var(--green-dark);}
  .cv-file-size{font-size:11.5px;color:var(--text-muted);}
  .cv-processing{text-align:center;padding:2rem;}
  .cv-processing-spinner{width:36px;height:36px;border:3px solid var(--green-light);border-top-color:var(--green);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 1rem;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .cv-processing p{font-size:13px;color:var(--text-muted);}
  /* BENCH PLAYER PROFILE OUTPUT */
  .bpp{font-family:'Aptos','Calibri Light',Calibri,sans-serif;font-size:13px;color:#333;line-height:1.5;}
  .bpp-header{margin-bottom:1.5rem;}
  .bpp-title{font-size:26px;font-weight:900;color:#333;margin-bottom:2px;}
  .bpp-title span{color:var(--green);}
  .bpp-name{font-size:22px;font-weight:700;color:#333;margin:1rem 0 2px;}
  .bpp-role{font-size:14px;font-weight:700;color:var(--green);margin-bottom:.75rem;}
  .bpp-contact{display:flex;gap:1.5rem;font-size:12.5px;color:var(--text-muted);margin-bottom:1rem;flex-wrap:wrap;}
  .bpp-contact span{display:flex;align-items:center;gap:5px;}
  .bpp-contact svg{width:13px;height:13px;}
  .bpp-summary{font-size:13px;color:#444;line-height:1.6;margin-bottom:1.5rem;}
  .bpp-section-title{font-size:14px;font-weight:700;color:#333;margin-bottom:.75rem;padding-bottom:4px;border-bottom:1.5px solid var(--green-light);}
  .bpp-expertise-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid #ddd;margin-bottom:1.5rem;}
  .bpp-expertise-col-header{background:#f5f5f5;padding:.5rem .75rem;font-size:12px;font-weight:700;color:#333;border-right:1px solid #ddd;border-bottom:1px solid #ddd;}
  .bpp-expertise-col-header:last-child{border-right:none;}
  .bpp-expertise-cell{padding:.5rem .75rem;font-size:12px;color:#444;border-right:1px solid #ddd;border-bottom:1px solid #ddd;vertical-align:top;}
  .bpp-expertise-cell:last-child{border-right:none;}
  .bpp-expertise-row:last-child .bpp-expertise-cell{border-bottom:none;}
  .bpp-exp-table{width:100%;border-collapse:collapse;margin-bottom:1.5rem;}
  .bpp-exp-table td{padding:.5rem 0;border-bottom:1px solid #eee;vertical-align:top;}
  .bpp-exp-table tr:last-child td{border-bottom:none;}
  .bpp-exp-org{font-weight:700;font-size:13px;color:#333;width:38%;}
  .bpp-exp-role{font-size:13px;color:#444;width:37%;}
  .bpp-exp-dates{font-size:12px;color:var(--text-muted);text-align:right;width:25%;}
  .bpp-highlights-table{width:100%;border-collapse:collapse;margin-bottom:1.5rem;border:1px solid #ddd;}
  .bpp-highlights-table th{background:#f5f5f5;padding:.5rem .75rem;font-size:12px;font-weight:700;color:#333;text-align:left;border-bottom:1px solid #ddd;border-right:1px solid #ddd;}
  .bpp-highlights-table th:last-child{border-right:none;}
  .bpp-highlights-table td{padding:.5rem .75rem;font-size:12px;color:#444;border-bottom:1px solid #eee;border-right:1px solid #ddd;vertical-align:top;}
  .bpp-highlights-table td:last-child{border-right:none;}
  .bpp-highlights-table tr:last-child td{border-bottom:none;}
  .bpp-highlights-table .bpp-hl-role{font-weight:700;color:#333;width:30%;}
  .bpp-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem;}
  .bpp-list{list-style:none;padding:0;}
  .bpp-list li{font-size:12.5px;color:#444;padding:3px 0;display:flex;align-items:flex-start;gap:6px;}
  .bpp-list li::before{content:"▪";color:var(--green);flex-shrink:0;margin-top:1px;}
  .bpp-footer{margin-top:1.5rem;padding-top:.75rem;border-top:1px solid #ddd;font-size:11px;color:var(--text-muted);text-align:center;}
  .bpp-watermark{color:#e0e0e0;font-size:10px;text-align:center;margin-top:4px;}
  .cv-history-item{display:flex;align-items:center;gap:10px;padding:.65rem 0;border-bottom:1px solid var(--grey-xlight);font-size:13px;}
  .cv-history-item:last-child{border-bottom:none;}
  .cv-history-name{flex:1;font-weight:700;color:var(--text);}
  .cv-history-date{font-size:11.5px;color:var(--text-muted);}
  @media(max-width:768px){.panel-layout{grid-template-columns:1fr;}.sp-layout{grid-template-columns:1fr;}nav{padding:0 1rem;}.nav-link span{display:none;}.fv-inline{grid-template-columns:1fr;}}
</style>
</head>
