// ── STATE ────────────────────────────────────────────────────────────────────
let activeFormId = 'new-project';

// ── NAVIGATION ───────────────────────────────────────────────────────────────
function showView(n) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  document.getElementById('view-' + n).classList.add('active');
  document.getElementById('nav-' + n).classList.add('active');
  window.scrollTo(0, 0);
  updateDashCount();
}

function updateDashCount() {
  const t = Object.values(FORMS).reduce((s, f) => s + f.responses.length, 0);
  const el = document.getElementById('dash-resp-count');
  if (el) el.textContent = t + ' response' + (t !== 1 ? 's' : '');
}

// ── FORM SELECTION ────────────────────────────────────────────────────────────
function selectForm(id) {
  activeFormId = id;
  document.querySelectorAll('.fli').forEach(i => i.classList.remove('active'));
  document.getElementById('fl-' + id).classList.add('active');
  const f = FORMS[id];
  document.getElementById('active-form-title').textContent = f.title;
  document.getElementById('share-url').value = 'https://hub.thebench.com.au/forms/' + f.slug;
  document.getElementById('embed-code').textContent = '<iframe src="https://hub.thebench.com.au/forms/' + f.slug + '" width="100%" height="700" frameborder="0"></iframe>';
  switchTab('form');
}

// ── TABS ──────────────────────────────────────────────────────────────────────
function switchTab(t) {
  ['form', 'responses', 'share'].forEach(x => {
    document.getElementById('tab-' + x).style.display = x === t ? 'block' : 'none';
    document.getElementById('tb-' + x).classList.toggle('active', x === t);
  });
  if (t === 'form') renderFormUI(activeFormId);
  if (t === 'responses') renderResponses();
  document.getElementById('resp-badge').textContent = FORMS[activeFormId].responses.length;
}

// ── FORM RENDERER ─────────────────────────────────────────────────────────────
function renderFormUI(fid) {
  const f = FORMS[fid];
  let h = `<div class="fv-wrap"><div class="fv-title">${f.title}</div><div class="fv-desc">${f.description}</div>`;

  f.sections.forEach(sec => {
    h += `<div class="fv-section">${sec.title}</div>`;
    let i = 0;
    while (i < sec.fields.length) {
      const fi = sec.fields[i];
      const nf = sec.fields[i + 1];
      // Pair short single-line fields side by side
      const short = x => x && ['text', 'email', 'date'].includes(x.type) && !x.tall;
      if (short(fi) && short(nf)) {
        h += `<div class="fv-inline">${renderField(fi)}${renderField(nf)}</div>`;
        i += 2;
      } else {
        h += renderField(fi);
        i++;
      }
    }
  });

  h += `<div class="form-submit-row">
    <button class="btn btn-primary" onclick="submitForm('${fid}')">
      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.2" style="width:14px;height:14px;"><polyline points="3 8 6 11 13 4"/></svg>
      Submit Form
    </button>
    <button class="btn btn-secondary" onclick="renderFormUI('${fid}')">Clear</button>
  </div></div>`;

  document.getElementById('tab-form').innerHTML = h;

  // Wire up conditional file upload for new-project
  if (fid === 'new-project') {
    const radios = document.querySelectorAll('input[name="fi-Confidentiality_COI_Required"]');
    radios.forEach(r => r.addEventListener('change', () => {
      const block = document.getElementById('coi-conditional');
      if (block) block.style.display = r.value === 'Yes' ? 'block' : 'none';
    }));
  }

  // Wire up file upload labels
  document.querySelectorAll('.fv-upload-area').forEach(area => {
    area.addEventListener('click', () => area.querySelector('input[type="file"]').click());
    const inp = area.querySelector('input[type="file"]');
    if (inp) inp.addEventListener('change', () => {
      const fn = area.querySelector('.fv-upload-name');
      if (fn) fn.textContent = inp.files[0] ? inp.files[0].name : '';
    });
  });
}

function renderField(fi) {
  const req = fi.req ? '<span class="req">*</span>' : '';
  let inp = '';

  if (['text', 'email', 'date'].includes(fi.type)) {
    inp = `<input class="fv-input" type="${fi.type}" id="fi-${fi.id}" placeholder="${fi.ph || ''}" />`;
  } else if (fi.type === 'textarea') {
    inp = `<textarea class="fv-textarea${fi.tall ? ' tall' : ''}" id="fi-${fi.id}" placeholder="${fi.ph || ''}"></textarea>`;
  } else if (fi.type === 'select') {
    inp = `<select class="fv-select" id="fi-${fi.id}">${fi.opts.map(o => `<option value="${o.includes('Select') ? '' : o}">${o}</option>`).join('')}</select>`;
  } else if (fi.type === 'radio') {
    inp = `<div class="fv-radio-group" id="fi-${fi.id}">${fi.opts.map(o => `<label class="fv-option-label"><input type="radio" name="fi-${fi.id}" value="${o}"/> ${o}</label>`).join('')}</div>`;
  } else if (fi.type === 'file') {
    // Conditional: only shown when COI = Yes
    return `<div id="coi-conditional" style="display:none;">
      <div class="fv-group">
        <label class="fv-label">${fi.label}${req}</label>
        <div class="fv-upload-area" id="fi-${fi.id}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:24px;height:24px;color:var(--text-muted);"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <p>Click to upload</p>
          <input type="file" accept=".pdf,.doc,.docx" />
          <div class="fv-upload-name"></div>
        </div>
      </div>
    </div>`;
  }

  return `<div class="fv-group"><label class="fv-label">${fi.label}${req}</label>${fi.hint ? `<div class="fv-hint">${fi.hint}</div>` : ''}${inp}</div>`;
}

// ── STORAGE LAYER ─────────────────────────────────────────────────────────────
// Currently uses localStorage for persistence.
// To switch to Azure Graph API, replace saveResponses() and loadAllResponses()
// with Graph API calls — everything else stays the same.

const STORAGE_KEY = 'thebench_responses';

function saveResponses() {
  const data = {};
  Object.keys(FORMS).forEach(fid => { data[fid] = FORMS[fid].responses; });
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch(e) { console.warn('Storage save failed:', e); }
}

function loadAllResponses() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return;
    const data = JSON.parse(raw);
    Object.keys(FORMS).forEach(fid => {
      if (data[fid] && Array.isArray(data[fid])) FORMS[fid].responses = data[fid];
    });
  } catch(e) { console.warn('Storage load failed:', e); }
}

// ── FORM SUBMISSION ───────────────────────────────────────────────────────────
function submitForm(fid) {
  const f = FORMS[fid];
  const entry = { _id: Date.now(), _submitted: new Date().toLocaleDateString('en-AU'), _status: 'New' };
  let valid = true, firstBad = null;

  f.sections.forEach(sec => sec.fields.forEach(fi => {
    if (fi.type === 'file') return;
    let v = '';
    if (fi.type === 'radio') {
      const c = document.querySelector(`input[name="fi-${fi.id}"]:checked`);
      v = c ? c.value : '';
    } else {
      const el = document.getElementById('fi-' + fi.id);
      v = el ? el.value.trim() : '';
    }
    if (fi.req && !v) {
      valid = false;
      const el = document.getElementById('fi-' + fi.id);
      if (el && !firstBad) { el.style.borderColor = '#dc2626'; el.scrollIntoView({ behavior: 'smooth', block: 'center' }); firstBad = el; }
    }
    entry[fi.id] = v;
  }));

  if (!valid) { showToast('Please fill in all required fields.'); return; }

  f.responses.unshift(entry);
  saveResponses(); // ← swap this for a Graph API call when Azure is ready
  if (fid === 'rsvp') syncRSVPToEmailList(entry);

  // Activity feed
  const feed = document.getElementById('activity-feed');
  const nameKey = fid === 'rsvp' ? 'Name' : (fid === 'project-highlights' ? 'Project_Title' : 'Project_Requester');
  const nm = entry[nameKey] || 'Someone';
  const item = document.createElement('div');
  item.className = 'act-item';
  item.innerHTML = `<div class="act-dot"></div><div class="act-text">New response to <strong>${f.title}</strong>${fid === 'rsvp' ? ' from ' + nm : ': ' + nm}</div><div class="act-time">Just now</div>`;
  feed.insertBefore(item, feed.firstChild);
  const ph = feed.querySelector('.act-dot.grey');
  if (ph && feed.children.length > 3) ph.closest('.act-item').remove();

  document.getElementById('resp-badge').textContent = f.responses.length;
  updateDashCount();
  renderFormUI(fid);
  showToast('Response submitted!', 'success');
}

// ── RESPONSES TABLE ───────────────────────────────────────────────────────────
function renderResponses() {
  const f = FORMS[activeFormId];
  const s = (document.getElementById('resp-search').value || '').toLowerCase();
  const fl = document.getElementById('resp-filter').value;
  const rows = f.responses.filter(r => (!fl || r._status === fl) && (!s || JSON.stringify(r).toLowerCase().includes(s)));
  const wrap = document.getElementById('resp-table-wrap');

  if (!rows.length) {
    wrap.innerHTML = `<div class="empty-state"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg><p>No responses yet${fl || s ? ' matching your filters' : ''}.</p></div>`;
    return;
  }

  const cols = {
    'new-project':        [['Project_Requester','Requester'],['Project_Name','Project'],['Client','Client'],['Project_Type','Type'],['Project_Start_Date','Start'],['_submitted','Submitted'],['_status','Status']],
    'project-highlights': [['Project_Title','Project'],['The_Bench_Project_Code','Code'],['Client','Client'],['Project_Dates','Dates'],['_submitted','Submitted'],['_status','Status']],
    'rsvp':               [['Name','Name'],['Attending','Attending'],['_submitted','Submitted'],['_status','Status']],
  }[activeFormId];

  let h = `<table class="data-table"><thead><tr>${cols.map(([, l]) => `<th>${l}</th>`).join('')}<th></th></tr></thead><tbody>`;
  rows.forEach(r => {
    h += `<tr>`;
    cols.forEach(([k]) => {
      if (k === '_status') h += `<td><span class="sdot ${r._status.toLowerCase()}">${r._status}</span></td>`;
      else h += `<td>${r[k] || '<span style="color:var(--text-muted)">—</span>'}</td>`;
    });
