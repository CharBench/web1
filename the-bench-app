// ── LIST STORAGE ──────────────────────────────────────────────────────────────
const LIST_KEY = 'thebench_lists';

function saveLists() {
  const data = {};
  Object.keys(LISTS).forEach(lid => { data[lid] = LISTS[lid].items; });
  try { localStorage.setItem(LIST_KEY, JSON.stringify(data)); } catch(e) { console.warn('List save failed:', e); }
