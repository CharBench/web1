  document.getElementById('detail-modal-footer').innerHTML =
    `<select class="form-select-full" style="max-width:160px;" id="dss">${statuses.map(s => `<option value="${s}"${r._status === s ? ' selected' : ''}>${s}</option>`).join('')}</select>
     <button class="btn btn-secondary" onclick="updateStatus(${id})">Update Status</button>
     <button class="btn btn-ghost btn-sm" style="margin-left:auto;" onclick="closeModal('detail-modal')">Close</button>`;
  document.getElementById('detail-modal').classList.add('open');
}

function updateStatus(id) {
  const r = FORMS[activeFormId].responses.find(x => x._id === id);
  r._status = document.getElementById('dss').value;
  saveResponses(); // persist status change too
  closeModal('detail-modal');
  renderResponses();
