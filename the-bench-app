  feed.insertBefore(item, feed.firstChild);
}

function renderAvailAdmin() {
  const s = (document.getElementById('avail-search').value || '').toLowerCase();
  const f = document.getElementById('avail-filter').value;
  const items = LISTS['availability'].items.filter(w => {
    const matchSearch = !s || (w.Name||'').toLowerCase().includes(s) || (w.Role||'').toLowerCase().includes(s);
    const statusMap = { available: 'Available', unavailable: 'Unavailable', date: 'Available from date', unknown: 'Not set' };
    const matchFilter = !f || (w.Status || 'Not set') === (statusMap[f] || f);
    return matchSearch && matchFilter;
  });

  const grid = document.getElementById('avail-admin-grid');
  if (!items.length) {
    grid.innerHTML = '<div class="empty-state" style="grid-column:1/-1;"><p>No Bench Warmers found.</p></div>';
    return;
  }

  grid.innerHTML = items.map(w => {
    const statusClass = w.Status === 'Available' ? 'available'
                      : w.Status === 'Unavailable' ? 'unavailable'
                      : w.Status === 'Available from date' ? 'date' : '';
    const statusLabel = w.Status || 'Not set';
    const dateLabel = w.Status === 'Available from date' && w.Available_From
      ? '<div style="font-size:11.5px;color:#1a5fbd;margin-top:3px;">From ' + new Date(w.Available_From + 'T00:00:00').toLocaleDateString('en-AU', {day:'numeric',month:'short',year:'numeric'}) + '</div>' : '';
    return `<div class="avail-card">
      <div class="avail-card-name">${w.Name}</div>
      <div class="avail-card-role">${w.Role || ''}</div>
      <div style="margin-bottom:.5rem;">
        <span class="avail-status-badge ${statusClass}">${statusLabel}</span>
        ${dateLabel}
      </div>
      ${w.Last_Updated ? '<div class="avail-last-updated">Updated ' + w.Last_Updated + '</div>' : ''}
    </div>`;
  }).join('');
}

function updateAvailDashCount() {
  const items = LISTS['availability'].items;
  const avail = items.filter(w => w.Status === 'Available' || w.Status === 'Available from date').length;
  const unavail = items.filter(w => w.Status === 'Unavailable').length;
  const a = document.getElementById('dash-avail-available');
  const u = document.getElementById('dash-avail-unavailable');
  if (a) a.textContent = avail + ' available';
  if (u) u.textContent = unavail + ' unavailable';
}

function openAddBenchWarmerModal() {
  document.getElementById('detail-modal-title').textContent = 'Add Bench Warmer';
  document.getElementById('detail-modal-body').innerHTML = `
