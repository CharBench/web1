function openDetail(id) {
  const f = FORMS[activeFormId];
  const r = f.responses.find(x => x._id === id);
  if (!r) return;
  document.getElementById('detail-modal-title').textContent = f.title + ' — Response';
  let body = `<div style="font-size:12px;color:var(--text-muted);margin-bottom:1rem;">Submitted ${r._submitted} &nbsp;·&nbsp; Status: <span class="sdot ${r._status.toLowerCase()}" style="font-size:12px;">${r._status}</span></div>`;
  f.sections.forEach(sec => {
    body += `<div style="font-size:11px;font-weight:700;color:var(--green-dark);text-transform:uppercase;letter-spacing:.07em;margin:1rem 0 .5rem;border-bottom:1px solid var(--green-light);padding-bottom:4px;">${sec.title}</div>`;
    sec.fields.forEach(fi => {
      if (fi.type === 'file') return;
      const v = r[fi.id];
      if (!v) return;
      body += `<div style="margin-bottom:.75rem;"><div style="font-size:12px;font-weight:700;color:var(--text-muted);margin-bottom:2px;">${fi.label}</div><div style="font-size:13.5px;color:var(--text);white-space:pre-wrap;">${v}</div></div>`;
