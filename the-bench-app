  if (!w || !selectedAvailStatus) { showToast('Please select an availability status.'); return; }

  const dateVal = document.getElementById('avail-date-picker').value;
  if (selectedAvailStatus === 'date' && !dateVal) { showToast('Please select a date.'); return; }

  w.Status = selectedAvailStatus === 'available' ? 'Available'
           : selectedAvailStatus === 'unavailable' ? 'Unavailable'
           : 'Available from date';
  w.Available_From = selectedAvailStatus === 'date' ? dateVal : '';
  w.Last_Updated = new Date().toLocaleDateString('en-AU');

  saveLists();
  updateListCounts();
  updateAvailDashCount();
  document.getElementById('avail-last-updated').textContent = 'Last updated ' + w.Last_Updated;
  showToast('Availability updated!', 'success');

  // Add to activity feed
